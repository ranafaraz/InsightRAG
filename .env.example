# Copy to `.env` and adjust. Never commit `.env`.

# ---------- Backends ----------
# Embeddings: "hash" (deterministic, no download — used by CI) | "sentence-transformers"
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Reranker: "lexical" (no download) | "cross-encoder"
RERANK_BACKEND=cross-encoder
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# LLM for generation: "stub" (extractive, offline) | "ollama" | "openai"
LLM_BACKEND=ollama
LLM_MODEL=llama3.1:8b

# ---------- Ollama (local, free) ----------
OLLAMA_BASE_URL=http://localhost:11434

# ---------- OpenAI (optional) ----------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ---------- Vector store ----------
# "memory" (numpy, no deps) | "chroma" (persistent, needs the `local` extra)
VECTOR_STORE=chroma
CHROMA_PATH=.chroma
COLLECTION_NAME=insightrag

# ---------- Retrieval / generation knobs ----------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVE_K=20          # candidates from hybrid retrieval before rerank
RERANK_TOP_N=5         # passages kept after rerank, fed to the LLM
HYBRID_ALPHA=0.5       # 0=BM25 only, 1=dense only
MIN_RERANK_SCORE=0.0   # below this, context is treated as insufficient -> refuse
MAX_CONTEXT_CHARS=8000
